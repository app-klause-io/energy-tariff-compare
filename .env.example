# Neon Postgres connection string
# Get this from your Neon dashboard: https://console.neon.tech
POSTGRES_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# API token for GET /api/feedback endpoint
# Generate a random token: openssl rand -base64 32
# Example: x4vTLtazayCRswxcds8YLHgoo0ZYw3y80emD/ju9D7M=
FEEDBACK_API_TOKEN=your_random_token_here
